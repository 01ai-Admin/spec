# Normalize line endings to LF on commit
* text=auto eol=lf

# Binary files — no line ending conversion
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.woff binary
*.woff2 binary
*.ttf  binary
*.eot  binary
*.mp4  binary
*.zip  binary
*.tgz  binary

# .01ai files are JSON — treat as text
*.01ai    text eol=lf
*.01bundle text eol=lf
